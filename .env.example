# ── Smart Scheduler Docker Environment ──
# Copy this to .env and fill in your values. NEVER commit .env to git.

# App URLs — replace with your EC2 public IP or domain
APP_FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
APP_BACKEND_URL=http://YOUR_EC2_PUBLIC_IP
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP/api

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Hugging Face (mood-detector)
HF_API_KEY=
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Mail (Mailgun SMTP)
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# JWT
JWT_SECRET=
